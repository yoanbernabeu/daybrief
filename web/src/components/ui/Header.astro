---
const base = import.meta.env.BASE_URL;
---

<header class="border-b border-db-border bg-db-dark/80 backdrop-blur-xl sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href={base} class="flex items-center gap-2 text-db-text font-bold text-[15px] hover:text-db-blue transition-colors">
      <div class="w-6 h-6 rounded-md bg-db-blue flex items-center justify-center">
        <span class="text-white text-xs font-extrabold">D</span>
      </div>
      DayBrief
    </a>
    <div class="flex items-center gap-1">
      <a href={`${base}/guide/`} class="px-3 py-1.5 text-sm text-db-text-secondary hover:text-db-text transition-colors rounded-md hover:bg-white/5">Docs</a>
      <a href={`${base}/admin/`} class="px-3 py-1.5 text-sm text-db-text-secondary hover:text-db-text transition-colors rounded-md hover:bg-white/5">Dashboard</a>
      <a
        href="https://github.com/yoanbernabeu/daybrief"
        target="_blank"
        rel="noopener noreferrer"
        class="ml-2 px-3.5 py-1.5 text-sm font-medium text-db-text bg-white/5 border border-db-border rounded-lg hover:bg-white/10 hover:border-white/20 transition-all"
      >
        GitHub
      </a>
    </div>
  </nav>
</header>
