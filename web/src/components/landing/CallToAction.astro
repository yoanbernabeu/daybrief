---
const base = import.meta.env.BASE_URL;
---

<section class="border-t border-db-border py-20 md:py-28">
  <div class="max-w-2xl mx-auto px-6 text-center">
    <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">
      Ready to automate your daily brief?
    </h2>
    <p class="text-db-text-secondary text-lg mb-8">
      Set up your newsletter in minutes. Manage everything from the web dashboard or directly in your repo.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a
        href={`${base}/admin/`}
        class="inline-flex items-center gap-2 bg-db-blue text-white px-6 py-3 rounded-xl text-sm font-semibold transition-all hover:bg-db-blue-hover hover:shadow-[0_0_24px_rgba(59,130,246,0.25)]"
      >
        Open Dashboard
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
      <a
        href="https://github.com/yoanbernabeu/daybrief"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-db-text border border-db-border px-6 py-3 rounded-xl text-sm font-semibold transition-all hover:bg-white/5 hover:border-white/20"
      >
        View on GitHub
      </a>
    </div>
  </div>
</section>
