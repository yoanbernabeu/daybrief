---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Login — DayBrief">
  <div class="min-h-[70vh] flex items-center justify-center py-16 px-6">
    <div class="w-full max-w-md">
      <div class="bg-db-card rounded-2xl border border-db-border p-8">
        <h1 class="text-2xl font-extrabold text-db-text mb-2">Connect your repo</h1>
        <p class="text-db-text-secondary text-sm mb-8">Enter your GitHub Personal Access Token and repository to manage your DayBrief configuration.</p>

        <form id="login-form" class="space-y-5">
          <div>
            <label for="repo" class="block text-sm font-medium text-db-text mb-1.5">Repository</label>
            <input
              type="text"
              id="repo"
              placeholder="owner/repo"
              required
              class="w-full px-4 py-2.5 rounded-xl bg-db-surface border border-db-border text-db-text placeholder:text-db-text-muted focus:outline-none focus:ring-2 focus:ring-db-blue/30 focus:border-db-blue/50 transition-colors"
            />
          </div>

          <div>
            <label for="token" class="block text-sm font-medium text-db-text mb-1.5">Personal Access Token</label>
            <input
              type="password"
              id="token"
              placeholder="github_pat_..."
              required
              class="w-full px-4 py-2.5 rounded-xl bg-db-surface border border-db-border text-db-text placeholder:text-db-text-muted focus:outline-none focus:ring-2 focus:ring-db-blue/30 focus:border-db-blue/50 transition-colors"
            />
            <p class="mt-2 text-xs text-db-text-muted">
              Need a token?
              <a
                href="https://github.com/settings/personal-access-tokens/new?description=DayBrief+Dashboard&resource_owner=&permissions=contents:write"
                target="_blank"
                rel="noopener noreferrer"
                class="text-db-blue hover:underline"
              >Create a fine-grained PAT</a> with <strong class="text-db-text-secondary">Contents: Read and write</strong> permission on your repo.
            </p>
          </div>

          <div id="error-msg" class="hidden text-sm text-red-400 bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3"></div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-db-blue text-white font-semibold py-3 rounded-xl transition-all hover:bg-db-blue-hover hover:shadow-[0_0_20px_rgba(59,130,246,0.2)] disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Connect
          </button>
        </form>
      </div>
    </div>
  </div>

  <script define:vars={{ base }}>
    const form = document.getElementById('login-form');
    const errorMsg = document.getElementById('error-msg');
    const submitBtn = document.getElementById('submit-btn');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Validating...';

      const repoInput = document.getElementById('repo').value.trim();
      const token = document.getElementById('token').value.trim();

      const parts = repoInput.split('/');
      if (parts.length !== 2 || !parts[0] || !parts[1]) {
        showError('Invalid format. Use owner/repo (e.g. yoanbernabeu/my-newsletter).');
        return;
      }

      const [owner, repo] = parts;

      try {
        const response = await fetch(`https://api.github.com/repos/${owner}/${repo}`, {
          headers: {
            Authorization: `Bearer ${token}`,
            Accept: 'application/vnd.github.v3+json',
          },
        });

        if (!response.ok) {
          if (response.status === 401) {
            showError('Invalid token. Please check your Personal Access Token.');
          } else if (response.status === 404) {
            showError('Repository not found. Check the owner/repo format and that your token has access.');
          } else {
            showError(`GitHub API error (${response.status}). Please try again.`);
          }
          return;
        }

        const data = await response.json();
        if (!data.permissions?.push) {
          showError('Your token does not have push access to this repository. The PAT needs Contents: Read and write permission.');
          return;
        }

        localStorage.setItem('daybrief_token', token);
        localStorage.setItem('daybrief_owner', owner);
        localStorage.setItem('daybrief_repo', repo);

        window.location.href = base + '/admin/';
      } catch {
        showError('Network error. Please check your connection and try again.');
      }
    });

    function showError(msg) {
      errorMsg.textContent = msg;
      errorMsg.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Connect';
    }
  </script>
</BaseLayout>
